{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "contributor.info",
  "version": "0.1.0",
  "identifier": "info.contributor.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "contributor.info",
        "width": 780,
        "height": 600,
        "minWidth": 420,
        "minHeight": 320,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://contributor.info https://avatars.githubusercontent.com data:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://contributor.info"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
